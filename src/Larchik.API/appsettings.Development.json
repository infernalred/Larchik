{
  "AllowedHosts": "*",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=5432;User Id=postgres;Password=Qwerty1;Database=larchik"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Cors": {
    "Origins": "https://localhost:5173, https://larchik.app:5173"
  },
  "Frontend": {
    "BaseUrl": "https://localhost:5173"
  },
  "Admin": {
    "Email": "admin@test.com",
    "Password": "Password!!!123"
  },
  "BackgroundJobs": {
    "Enabled": true,
    "SchedulerPollSeconds": 30,
    "ExecutorPollSeconds": 10,
    "ExecutorBatchSize": 5,
    "FxCbrDaily": {
      "Enabled": true,
      "HourUtc": 5,
      "MinuteUtc": 10,
      "MaxAttempts": 8,
      "RetryDelayMinutes": 20,
      "LockTimeoutMinutes": 5
    },
    "MoexPricesDaily": {
      "Enabled": true,
      "HourUtc": 19,
      "MinuteUtc": 20,
      "MaxAttempts": 8,
      "RetryDelayMinutes": 20,
      "LockTimeoutMinutes": 10,
      "Provider": "MOEX",
      "BaseUrl": "https://iss.moex.com/iss",
      "Boards": [ "TQBR", "TQTF", "TQIF", "TQCB", "TQOB" ]
    }
  }
}
