{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "BackgroundJobs": {
    "Enabled": true,
    "SchedulerPollSeconds": 30,
    "ExecutorPollSeconds": 10,
    "ExecutorBatchSize": 5,
    "FxCbrDaily": {
      "Enabled": true,
      "HourUtc": 5,
      "MinuteUtc": 10,
      "MaxAttempts": 8,
      "RetryDelayMinutes": 20,
      "LockTimeoutMinutes": 5
    }
  }
}
