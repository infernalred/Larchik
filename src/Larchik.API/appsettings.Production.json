{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Grafana.Loki" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/app-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "https://loki.example.com",
          "useInternalTimestamp": true,
          "labels": [
            {
              "key": "service",
              "value": "larchik-api"
            },
            {
              "key": "env",
              "value": "prod"
            }
          ]
        }
      }
    ],
    "Properties": {
      "Environment": "Production"
    }
  },
  "Import": {
    "MaxFileSizeMb": 10
  },
  "BackgroundJobs": {
    "Enabled": true,
    "SchedulerPollSeconds": 30,
    "ExecutorPollSeconds": 10,
    "ExecutorBatchSize": 5,
    "FxCbrDaily": {
      "Enabled": true,
      "HourUtc": 5,
      "MinuteUtc": 10,
      "MaxAttempts": 8,
      "RetryDelayMinutes": 20,
      "LockTimeoutMinutes": 5
    },
    "TbankPricesDaily": {
      "Enabled": true,
      "HourUtc": 21,
      "MinuteUtc": 0,
      "MaxAttempts": 8,
      "RetryDelayMinutes": 20,
      "LockTimeoutMinutes": 20,
      "Provider": "TBANK",
      "BaseUrl": "https://invest-public-api.tbank.ru/rest/tinkoff.public.invest.api.contract.v1.MarketDataService/GetCandles",
      "Token": "",
      "AllowInvalidTls": false,
      "MaxHistoryLookbackDays": 7,
      "MaxParallelism": 6,
      "CountryExclusions": []
    },
    "TbankInstrumentInfoDaily": {
      "Enabled": false,
      "HourUtc": 20,
      "MinuteUtc": 30,
      "MaxAttempts": 8,
      "RetryDelayMinutes": 20,
      "LockTimeoutMinutes": 20,
      "BaseUrl": "https://invest-public-api.tbank.ru/rest/tinkoff.public.invest.api.contract.v1.InstrumentsService/GetInstrumentBy",
      "Token": "",
      "AllowInvalidTls": false,
      "MaxParallelism": 6,
      "CountryExclusions": []
    }
  }
}
