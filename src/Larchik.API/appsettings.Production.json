{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Grafana.Loki" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/app-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "https://loki.example.com",
          "username": "%LOKI_USERNAME%",
          "password": "%LOKI_PASSWORD%",
          "labels": { "app": "larchik-api", "env": "prod" }
        }
      }
    ]
  },
  "Import": {
    "MaxFileSizeMb": 10
  },
  "BackgroundJobs": {
    "Enabled": true,
    "SchedulerPollSeconds": 30,
    "ExecutorPollSeconds": 10,
    "ExecutorBatchSize": 5,
    "FxCbrDaily": {
      "Enabled": true,
      "HourUtc": 5,
      "MinuteUtc": 10,
      "MaxAttempts": 8,
      "RetryDelayMinutes": 20,
      "LockTimeoutMinutes": 5
    }
  }
}
