{
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Grafana.Loki" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/jobs-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "https://loki.example.com",
          "useInternalTimestamp": true,
          "labels": [
            {
              "key": "service",
              "value": "larchik-jobs"
            },
            {
              "key": "env",
              "value": "prod"
            }
          ]
        }
      }
    ],
    "Properties": {
      "Environment": "Production"
    }
  },
  "BackgroundJobs": {
    "MoexPricesDaily": {
      "Enabled": true,
      "Boards": [ "TQBR", "TQTF", "TQIF", "TQCB", "TQOB", "CETS", "MTQR" ]
    },
    "TbankPricesDaily": {
      "AllowInvalidTls": true,
      "CountryExclusions": [ "RU" ]
    }
  }
}
