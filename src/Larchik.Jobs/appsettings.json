{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ]
  },
  "BackgroundJobs": {
    "Enabled": true,
    "SchedulerPollSeconds": 30,
    "ExecutorPollSeconds": 10,
    "ExecutorBatchSize": 5,
    "FxCbrDaily": {
      "Enabled": true,
      "HourUtc": 5,
      "MinuteUtc": 10,
      "MaxAttempts": 8,
      "RetryDelayMinutes": 20,
      "LockTimeoutMinutes": 5
    },
    "MoexPricesDaily": {
      "Enabled": false,
      "HourUtc": 19,
      "MinuteUtc": 20,
      "MaxAttempts": 8,
      "RetryDelayMinutes": 20,
      "LockTimeoutMinutes": 10,
      "Provider": "MOEX",
      "BaseUrl": "https://iss.moex.com/iss",
      "Boards": [ "TQBR", "TQTF", "TQIF", "TQCB", "TQOB" ]
    },
    "TbankPricesDaily": {
      "Enabled": true,
      "HourUtc": 21,
      "MinuteUtc": 0,
      "MaxAttempts": 8,
      "RetryDelayMinutes": 20,
      "LockTimeoutMinutes": 20,
      "Provider": "TBANK",
      "BaseUrl": "https://invest-public-api.tbank.ru/rest/tinkoff.public.invest.api.contract.v1.MarketDataService/GetCandles",
      "Token": "",
      "AllowInvalidTls": false,
      "MaxHistoryLookbackDays": 7,
      "MaxParallelism": 6,
      "CountryExclusions": []
    },
    "TbankInstrumentInfoDaily": {
      "Enabled": false,
      "HourUtc": 20,
      "MinuteUtc": 30,
      "MaxAttempts": 8,
      "RetryDelayMinutes": 20,
      "LockTimeoutMinutes": 20,
      "BaseUrl": "https://invest-public-api.tbank.ru/rest/tinkoff.public.invest.api.contract.v1.InstrumentsService/GetInstrumentBy",
      "Token": "",
      "AllowInvalidTls": false,
      "MaxParallelism": 6,
      "CountryExclusions": []
    }
  }
}
